NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/watsapp?schema=public
REDIS_URL=redis://localhost:6379
API_PORT=4000
WEB_PORT=3000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
ENCRYPTION_KEY=change-me-32-byte-minimum-session-key
API_KEY_PEPPER=change-me-api-key-pepper-at-least-32-characters
WEBHOOK_SIGNING_SECRET=change-me-webhook-secret-at-least-32-characters
LOCAL_STORAGE_ROOT=./storage
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace-with-openai-compatible-key
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
AI_AUDIO_MODEL=whisper-1
AI_TTS_MODEL=tts-1
AI_MONTHLY_BUDGET_CENTS=10000
AI_RATE_LIMIT_PER_MINUTE=60

# TikTok Business API (https://business-api.tiktok.com/portal/docs)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/v1/tiktok/oauth/callback
