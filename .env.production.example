# ============================================================================
# Production environment for VPS deployment (docker-compose.prod.yml).
# Copy to `.env` on the server and replace every placeholder.
#   cp .env.production.example .env
# Generate each secret with:
#   openssl rand -hex 32
# ============================================================================

NODE_ENV=production

# --- Domains (set DNS A records for both to your VPS IP) --------------------
# Used by Caddy for automatic HTTPS and by the apps for URLs/CORS.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# --- Database (internal Docker hostname = service name "postgres") ----------
POSTGRES_USER=watsapp
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=watsapp
DATABASE_URL=postgresql://watsapp:CHANGE_ME_strong_db_password@postgres:5432/watsapp?schema=public

# --- Redis (internal Docker hostname = service name "redis") ----------------
REDIS_URL=redis://redis:6379

# --- Public URLs ------------------------------------------------------------
API_PORT=4000
WEB_PORT=3000
API_PUBLIC_URL=https://api.example.com
WEB_PUBLIC_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com

# --- Frontend build-time URLs (must equal the public API domain) ------------
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_SOCKET_URL=https://api.example.com

# --- Secrets (MUST be at least 32 characters each) --------------------------
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
ENCRYPTION_KEY=CHANGE_ME_min_32_chars_encryption_key
API_KEY_PEPPER=CHANGE_ME_min_32_chars_api_key_pepper
WEBHOOK_SIGNING_SECRET=CHANGE_ME_min_32_chars_webhook_secret

# --- Storage (mounted volume inside the container) --------------------------
LOCAL_STORAGE_ROOT=/app/storage

# --- AI provider (OpenAI-compatible) ----------------------------------------
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace-with-openai-compatible-key
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
AI_AUDIO_MODEL=whisper-1
AI_TTS_MODEL=tts-1
AI_MONTHLY_BUDGET_CENTS=10000
AI_RATE_LIMIT_PER_MINUTE=60

# --- Optional integrations --------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.example.com/api/v1/tiktok/oauth/callback
META_VERIFY_TOKEN=
META_APP_SECRET=
